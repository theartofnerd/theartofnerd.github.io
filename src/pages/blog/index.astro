---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import RetroHeader from '../../components/RetroHeader.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="retro-body">
		<RetroHeader />
		<div class="page-wrap">
			<div class="content-box">
				<h1 class="page-title">■ にっき / Blog ■</h1>
				<ul class="post-list">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>★ {post.data.title}</a>
								<span class="date">
									(<FormattedDate date={post.data.pubDate} />)
								</span>
							</li>
						))
					}
				</ul>
			</div>
		</div>
		<Footer />

		<style>
			.retro-body {
				margin: 0;
				background: #ffffcc;
				color: #663300;
				font-family: 'Comic Sans MS', 'MS PGothic', sans-serif;
			}
			.page-wrap {
				max-width: 800px;
				margin: 12px auto;
				padding: 0 8px;
			}
			.content-box {
				background: #fff;
				border: 2px solid #ff9900;
				padding: 16px 20px;
			}
			.page-title {
				background: #ffcc00;
				color: #663300;
				font-size: 20px;
				padding: 6px 10px;
				margin: 0 0 16px;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-list li {
				padding: 6px 0;
				border-bottom: 1px dashed #ff9900;
				font-size: 14px;
			}
			.post-list a {
				color: #0000ee;
				text-decoration: none;
			}
			.post-list a:hover {
				background: #ffff00;
				text-decoration: underline;
			}
			.date {
				color: #996633;
				font-size: 12px;
				margin-left: 6px;
			}
		</style>
	</body>
</html>
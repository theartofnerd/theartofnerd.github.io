---
import Layout from '../layouts/RetroLayout.astro';

const certifications = [
	{ name: 'Zero2Automated', issuer: 'Zero2Automated' },
	{ name: 'OSCE3(Offsec Certified Expert 3)', issuer: 'Offsec' },
	{ name: 'OSED(Offsec Exploit Developer)', issuer: 'Offsec' },
	{ name: 'OSWE(Offsec Web Expert)', issuer: 'Offsec' },
	{ name: 'OSEP(Offsec Experienced Penetration Tester)', issuer: 'Offsec' },
	{ name: 'OSMR(Offsec macOS Researcher)', issuer: 'Offsec' },
	{ name: 'OSCP+(Offsec Certified Professional Plus)', issuer: 'Offsec' },
	{ name: 'OSTH(Offsec Threat Hunter)', issuer: 'Offsec' },
	{ name: 'OSIR(Offsec Incident Responder)', issuer: 'Offsec' },
	{ name: 'OSDA(Offsec Defense Analyst)', issuer: 'Offsec' },
	{ name: 'OSWA(Offsec Web Assessor)', issuer: 'Offsec' },
	{ name: 'OSWP(Offsec Wireless Professional)', issuer: 'Offsec' },
	{ name: 'KLCP(Kali Linux Certified Professional)', issuer: 'Offsec' },
	{ name: 'OSCC(Offsec CyberCore Security Essentials)', issuer: 'Offsec' },
	{ name: 'OSCC-SJD(Offsec CyberCore Secure Java Development Essentials)', issuer: 'Offsec' },
	{ name: 'eJPTv2(eLearn Security Junior Penetration Tester)', issuer: 'INE' },
	{ name: 'eCPPTv2(eLearn Security Certified Professional Penetration Tester)', issuer: 'INE' },
	{ name: 'eCIR(eLearn Security Certified Incident Responder)', issuer: 'INE' },
	{ name: 'eCTHPv2(eLearn Security Certified Threat Hunting Professional)', issuer: 'INE' },
	{ name: 'eCDFP(eLearn Security Digital Forensics Professional)', issuer: 'INE' },
];
---

<Layout title="Certifications" description="取得した資格の一覧">
	<p>取得した資格の一覧（失効済み含む）</p>

	<ul class="cert-list">
		{
			certifications.map((cert) => (
				<li class="cert-item">
					<span class="cert-name">★ {cert.name}</span>
					<span class="cert-issuer">［{cert.issuer}］</span>
				</li>
			))
		}
	</ul>
</Layout>

<style>
	.cert-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.cert-item {
		padding: 6px 0;
		border-bottom: 1px dashed #ff9900;
		font-size: 14px;
	}
	.cert-name {
		font-weight: bold;
		color: #663300;
	}
	.cert-issuer {
		color: #996633;
		font-size: 12px;
		margin-left: 6px;
	}
</style>
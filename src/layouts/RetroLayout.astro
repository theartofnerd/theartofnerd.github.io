---
import BaseHead from '../components/BaseHead.astro';
import RetroHeader from '../components/RetroHeader.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="retro-body">
		<RetroHeader />
		<div class="page-wrap">
			<div class="content-box">
				<h1 class="page-title">{title}</h1>
				<slot />
			</div>
		</div>
		<Footer />

		<style>
			.retro-body {
				margin: 0;
				background: #ffffcc;
				color: #663300;
				font-family: 'Comic Sans MS', 'MS PGothic', sans-serif;
			}
			.page-wrap {
				max-width: 800px;
				margin: 12px auto;
				padding: 0 8px;
			}
			.content-box {
				background: #ffffff;
				border: 2px solid #ff9900;
				padding: 16px 20px;
			}
			.page-title {
				background: #ffcc00;
				color: #663300;
				font-size: 20px;
				padding: 6px 10px;
				margin: 0 0 16px;
			}
			.content-box :global(h2) {
				background: #ffcc00;
				color: #663300;
				font-size: 16px;
				padding: 3px 8px;
				margin: 20px 0 8px;
			}
			.content-box :global(h3) {
				color: #cc0066;
				font-size: 15px;
				margin: 14px 0 4px;
			}
			.content-box :global(p),
			.content-box :global(li) {
				font-size: 14px;
				line-height: 1.8;
			}
			.content-box :global(a) {
				color: #0000ee;
			}
			.content-box :global(hr) {
				border: 0;
				border-top: 1px dashed #ff9900;
			}
		</style>
	</body>
</html>